# LLM: any langchain init_chat_model string, e.g. openai:gpt-5.1, anthropic:claude-sonnet-5
LLM_MODEL=openai:gpt-5.1
OPENAI_API_KEY=

# Interactive Brokers (TWS or IB Gateway must be running with API enabled)
IB_HOST=127.0.0.1
IB_PORT=7497            # 7497 = TWS paper, 4002 = Gateway paper, 7496/4001 = LIVE
IB_CLIENT_ID=17
TRADING_MODE=paper      # "live" requires also changing IB_PORT — deliberate two-field change
MARKET_DATA_TYPE=1      # 1=live, 3=delayed (auto-fallback if no subscription)

# Strategy
SYMBOL=SPY
MAX_TRADES_PER_DAY=2
MAX_CONTRACTS=4
MAX_PREMIUM_USD=500
STOP_BUFFER_CENTS=40
NO_NEW_ENTRIES_AFTER=15:30
