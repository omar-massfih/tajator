# LLM backend, one of:
#   codex                      -> Codex CLI with your ChatGPT subscription (`codex login` once, no API key)
#   codex:<model>              -> Codex CLI with a specific model
#   openai:gpt-5.1             -> OpenAI API (needs OPENAI_API_KEY)
#   anthropic:claude-sonnet-5  -> any other langchain init_chat_model string + its key
LLM_MODEL=codex
OPENAI_API_KEY=

# Interactive Brokers (IB Gateway must be running with API enabled)
IB_HOST=127.0.0.1
IB_PORT=4002            # 4002 = IB Gateway paper, 4001 = LIVE
IB_CLIENT_ID=17
TRADING_MODE=paper      # "live" requires also changing IB_PORT — deliberate two-field change
MARKET_DATA_TYPE=1      # 1=live, 3=delayed (auto-fallback if no subscription)
ORDER_TIMEOUT_S=120     # paper-sim fills can take minutes without live option data
FILL_GRACE_S=15         # post-cancel window for late execution reports
BLOCK_ENTRIES_ON_DELAYED_DATA=true  # refuse entries when quotes fell back to delayed

# Strategy
SYMBOLS=SPY,AAPL,MSFT,NVDA
MAX_TRADES_PER_DAY=2
MAX_CONTRACTS=4
MAX_PREMIUM_USD=500
STOP_BUFFER_CENTS=40
NO_NEW_ENTRIES_AFTER=15:30
PROTECTIVE_STOP=false   # broker-side GTC stop (backstop for the in-loop mental stop);
                        # enable after verifying with `tajator test-order --with-stop`
ORDER_REF_PREFIX=tajator  # provenance tag on every order tajator places

# Level quality gates (strategy notes 07/08: only clean, prominent levels trade)
DOUBLE_MIN_TOUCH_SEPARATION_BARS=10   # minutes between a double's two touches
DOUBLE_MIN_PULLBACK_PCT=0.002         # retrace required between the touches
MIN_LEVEL_DIST_FROM_OPEN_PCT=0.003    # levels closer to the day's open are untradable
SWING_WINDOW_BARS=3                   # bars each side that must be lower/higher for a swing
LEVEL_CLUSTER_TOL_PCT=0.0015          # swings within this fraction of each other form one level

# Setup detection tuning (how price must approach a level to become a candidate)
APPROACH_BAND_PCT=0.003    # price within this fraction of the level
OVERSHOOT_BAND_PCT=0.001   # slight poke through the level still counts
SPEED_WINDOW_BARS=3        # bars used to measure the move into the level
MIN_SPEED_PCT=0.0012       # net move over the window, fraction of price
FAST_APPROACH_SPEED_MULT=2.0   # approaches >= this x MIN_SPEED_PCT are "fast" ...
REJECTION_WICK_MIN_FRAC=0.25   # ... and need a rejection wick on the entry bar (0 disables)
TRADE_FLIPPED_LEVELS=false     # role-reversed levels (broken support as resistance, ...) stay chart-context only

# Stop-distance rule (the LLM's stop must sit this far beyond the level)
STOP_MIN_CENTS=20
STOP_MAX_CENTS=60

# Re-entry discipline: a level that stopped us out is dead this long (0 disables)
STOP_COOLDOWN_MINUTES=30

# Runner stop after the first scale-out: breakeven (default — room toward hod/lod)
# or first_target (tighter lock at the scale-out price)
RUNNER_STOP=breakeven

# Telegram trade notifications (optional — leave blank to disable, live runs only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
